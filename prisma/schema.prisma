generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Siswa {
  id String @id @default(uuid())
  nis String 
  nama String
  password String
  status_bayar StatusSiswa @default(unpaid)
  createAt DateTime @default(now())
  Transaksi Transaksi[]
}

model Transaksi {
  id String @id @default(uuid())
  nominal Int
  tanggal_bayar DateTime @default(now())
  siswa_id String
  createAt DateTime @default(now())
  status Status @default(pending)
  verifiedAt DateTime?
  siswa Siswa @relation(fields: [siswa_id], references: [id])
}

enum StatusSiswa {
  paid
  unpaid
}

enum Status {
  pending
  waiting
  success
}